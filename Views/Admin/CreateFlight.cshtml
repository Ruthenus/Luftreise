@model Luftreise.Models.Admin.AdminFlightFormViewModel

@{
    ViewData["Title"] = "Додати рейс";
}

<section class="profile-page">
    <div class="profile-wrapper">
        <div class="profile-details-card">
            <h2>Додати рейс</h2>

            <form asp-controller="Admin" asp-action="CreateFlight" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="profile-grid">
                    <div class="profile-field">
                        <label asp-for="FlightNumber">Номер рейсу</label>
                        <input asp-for="FlightNumber" />
                        <span asp-validation-for="FlightNumber" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="AirlineName">Авіакомпанія</label>
                        <input asp-for="AirlineName" />
                        <span asp-validation-for="AirlineName" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="DepartureAirportId">Аеропорт вильоту</label>
                        <select asp-for="DepartureAirportId" asp-items="ViewBag.Airports"></select>
                        <span asp-validation-for="DepartureAirportId" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="ArrivalAirportId">Аеропорт прильоту</label>
                        <select asp-for="ArrivalAirportId" asp-items="ViewBag.Airports"></select>
                        <span asp-validation-for="ArrivalAirportId" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="DepartureTime">Час вильоту</label>
                        <input asp-for="DepartureTime"
                               type="datetime-local"
                               value="@Model.DepartureTime.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="DepartureTime" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="ArrivalTime">Час прильоту</label>
                        <input asp-for="ArrivalTime"
                               type="datetime-local"
                               value="@Model.ArrivalTime.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="ArrivalTime" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="Price">Ціна</label>
                        <input asp-for="Price" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="FlightClass">Клас</label>
                        <input asp-for="FlightClass" />
                        <span asp-validation-for="FlightClass" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="AvailableSeats">Доступні місця</label>
                        <input asp-for="AvailableSeats" type="number" />
                        <span asp-validation-for="AvailableSeats" class="field-validation"></span>
                    </div>

                    <div class="profile-field">
                        <label asp-for="TotalSeats">Усього місць</label>
                        <input asp-for="TotalSeats" type="number" />
                        <span asp-validation-for="TotalSeats" class="field-validation"></span>
                    </div>
                </div>

                <button type="submit" class="auth-btn">Зберегти рейс</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
