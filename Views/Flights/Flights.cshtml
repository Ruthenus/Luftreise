                <!-- 4 -->
                <div class="flight-card" data-base-price="259">
                    <div class="flight-top">
                        <div class="airline-box">
                            <div class="airline-icon">✈</div>
                            <div>
                                <h3>Luftreise Airways</h3>
                                <p>LR 1245</p>
                            </div>
                        </div>
                    </div>

                    <div class="flight-main">
                        <div class="flight-time-block">
                            <h2>21:10</h2>
                            <p>KBP</p>
                            <span>@Model.From</span>
                        </div>

                        <div class="flight-middle">
                            <div class="flight-line"></div>
                            <p>3г 20хв</p>
                            <span>Прямий</span>
                        </div>

                        <div class="flight-time-block">
                            <h2>00:30</h2>
                            <p>CDG</p>
                            <span>@Model.To</span>
                        </div>

                        <div class="flight-price" data-base-price="259">
                            <div class="flight-rating">
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star">★</span>
                                <span class="star">★</span>
                                <span class="star">★</span>
                            </div>

                            <h2><span class="price-value">259</span> €</h2>
                            <p>за <span class="passenger-label">1</span> пас.</p>

                            <a asp-controller="Flights"
                               asp-action="Booking"
                               asp-route-id="4"
                               asp-route-airline="Luftreise Airways"
                               asp-route-flightNumber="LR 1240"
                               asp-route-fromCity="@Model.From"
                               asp-route-toCity="@Model.To"
                               asp-route-departureTime="21:10"
                               asp-route-arrivalTime="00:30"
                               asp-route-flightDate="@Model.FlightDate.ToString("yyyy-MM-dd")"
                               asp-route-flightClass="Економ+"
                               asp-route-price="259"
                               class="booking-btn">
                                Забронювати
                            </a>
                        </div>
                    </div>

                    <div class="flight-footer">
                        <span>@Model.FlightDate.ToString("dd MMMM yyyy")</span>
                        <span>Економ</span>
                        <span>16 місць</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
@section Scripts {
    <script>
        const priceRange = document.getElementById("priceRange");
        const priceValue = document.getElementById("priceValue");

        const minusBtn = document.getElementById("minusPassengers");
        const plusBtn = document.getElementById("plusPassengers");
        const passengerCountEl = document.getElementById("passengerCount");
        const resultsCountEl = document.querySelector(".results-count");

        const resetBtn = document.querySelector(".reset-btn");

        const checkboxes = document.querySelectorAll(".checkbox-row input");

        let passengerCount = 1;


        const cards = document.querySelectorAll(".flight-card");
        cards[0].dataset.class = "econom";
        cards[1].dataset.class = "business";
        cards[2].dataset.class = "first";
        cards[3].dataset.class = "econom";

        function updateFlights() {
            const maxPrice = parseInt(priceRange.value);
            priceValue.textContent = maxPrice;
            passengerCountEl.textContent = passengerCount;

            let visibleCount = 0;

            const selectedClasses = [];
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    selectedClasses.push(cb.nextElementSibling.textContent.trim());
                }
            });

            document.querySelectorAll(".flight-card").forEach(card => {
                const basePrice = parseInt(card.dataset.basePrice);
                const totalPrice = basePrice * passengerCount;

                const className = card.querySelector(".flight-footer span:nth-child(2)").textContent.trim();

                const priceBox = card.querySelector(".flight-price");
                priceBox.querySelector(".price-value").textContent = totalPrice;
                priceBox.querySelector(".passenger-label").textContent = passengerCount;

                const classAllowed = selectedClasses.includes(className);
                const priceAllowed = totalPrice <= maxPrice;

                if (classAllowed && priceAllowed) {
                    card.style.display = "";
                    visibleCount++;
                } else {
                    card.style.display = "none";
                }
            });

            resultsCountEl.textContent = `Знайдено ${visibleCount} рейсів`;
        }


        priceRange.addEventListener("input", updateFlights);


        plusBtn.addEventListener("click", function () {
            passengerCount++;
            updateFlights();
        });


        minusBtn.addEventListener("click", function () {
            if (passengerCount > 1) {
                passengerCount--;
                updateFlights();
            }
        });


        checkboxes.forEach(cb => {
            cb.addEventListener("change", updateFlights);
        });


        resetBtn.addEventListener("click", function () {
            priceRange.value = 15000;
            passengerCount = 1;

            checkboxes.forEach(cb => cb.checked = true);

            updateFlights();
        });

        updateFlights();
    </script>
}