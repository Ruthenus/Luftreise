@model Luftreise_Command_project_.Models.SearchModels


@{
    ViewData["Title"] = "Рейси";

    var from = Model?.From ?? "";
    var to = Model?.To ?? "";
    var flightDate = Model?.FlightDate != default
        ? Model.FlightDate.ToString("yyyy-MM-dd")
        : "";
}

<section class="booking-page">
    <div class="booking-container">

        <div class="booking-header">
            <h1>Рейси: @Model.From → @Model.To</h1>

            <div class="booking-meta">
                <p>
                    Дата: @Model.FlightDate.ToString("yyyy-MM-dd")
                    <span class="dot">•</span>
                    Пасажири:
                </p>

                <div class="passenger-counter">
                    <button type="button" id="minusPassengers">−</button>
                    <span id="passengerCount">1</span>
                    <button type="button" id="plusPassengers">+</button>
                </div>
            </div>
        </div>

        <div class="booking-content">

            <aside class="filters-panel">
                <div class="filters-card">
                    <h2>Фільтри</h2>

                    <div class="filter-group">
                        <label for="priceRange">Максимальна ціна: <span id="priceValue">15000</span> €</label>
                        <input type="range" id="priceRange" min="50" max="15000" value="15000" />
                    </div>

                    <div class="filter-group">
                        <h3>Клас</h3>

                        <label class="checkbox-row">
                            <input type="checkbox" checked />
                            <span>Економ</span>
                        </label>

                        <label class="checkbox-row">
                            <input type="checkbox" checked />
                            <span>Бізнес</span>
                        </label>

                        <label class="checkbox-row">
                            <input type="checkbox" checked />
                            <span>Перший клас</span>
                        </label>
                    </div>

                    <button type="button" class="reset-btn">Скинути фільтри</button>
                </div>
            </aside>

            <div class="flights-section">
                <p class="results-count">Знайдено 4 рейсів</p>

                <!-- 1 -->
                <div class="flight-card" data-base-price="299">
                    <div class="flight-top">
                        <div class="airline-box">
                            <div class="airline-icon">✈</div>
                            <div>
                                <h3>Luftreise Airways</h3>
                                <p>LR 1234</p>
                            </div>
                        </div>
                    </div>

                    <div class="flight-main">
                        <div class="flight-time-block">
                            <h2>08:30</h2>
                            <p>KBP</p>
                            <span>@Model.From</span>
                        </div>

                        <div class="flight-middle">
                            <div class="flight-line"></div>
                            <p>3г 15хв</p>
                            <span>Прямий</span>
                        </div>

                        <div class="flight-time-block">
                            <h2>11:45</h2>
                            <p>CDG</p>
                            <span>@Model.To</span>
                        </div>

                        <div class="flight-price" data-base-price="299">
                            <div class="flight-rating">
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                            </div>

                            <h2><span class="price-value">299</span> €</h2>
                            <p>за <span class="passenger-label">1</span> пас.</p>

                            <a asp-controller="Flights"
                               asp-action="Booking"
                               asp-route-id="1"
                               asp-route-airline="Luftreise Airways"
                               asp-route-flightNumber="LR 1234"
                               asp-route-fromCity="@Model.From"
                               asp-route-toCity="@Model.To"
                               asp-route-departureTime="08:30"
                               asp-route-arrivalTime="11:45"
                               asp-route-flightDate="@Model.FlightDate.ToString("yyyy-MM-dd")"
                               asp-route-flightClass="Економ"
                               asp-route-price="299"
                               class="booking-btn">
                                Забронювати
                            </a>
                        </div>
                    </div>

                    <div class="flight-footer">
                        <span>@Model.FlightDate.ToString("dd MMMM yyyy")</span>
                        <span>Економ</span>
                        <span>12 місць</span>
                    </div>
                </div>

                <!-- 2 -->
                <div class="flight-card" data-base-price="349">
                    <div class="flight-top">
                        <div class="airline-box">
                            <div class="airline-icon">✈</div>
                            <div>
                                <h3>Luftreise Airways</h3>
                                <p>LR 1236</p>
                            </div>
                        </div>
                    </div>

                    <div class="flight-main">
                        <div class="flight-time-block">
                            <h2>14:15</h2>
                            <p>KBP</p>
                            <span>@Model.From</span>
                        </div>

                        <div class="flight-middle">
                            <div class="flight-line"></div>
                            <p>3г 15хв</p>
                            <span>Прямий</span>
                        </div>

                        <div class="flight-time-block">
                            <h2>17:30</h2>
                            <p>CDG</p>
                            <span>@Model.To</span>
                        </div>

                        <div class="flight-price" data-base-price="349">
                            <div class="flight-rating">
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star active">★</span>
                                <span class="star">★</span>
                            </div>

                            <h2><span class="price-value">349</span> €</h2>
                            <p>за <span class="passenger-label">1</span> пас.</p>

                            <a asp-controller="Flights"
                               asp-action="Booking"
                               asp-route-id="2"
                               asp-route-airline="Luftreise Airways"
                               asp-route-flightNumber="LR 1236"
                               asp-route-fromCity="@Model.From"
                               asp-route-toCity="@Model.To"
                               asp-route-departureTime="14:15"
                               asp-route-arrivalTime="17:30"
                               asp-route-flightDate="@Model.FlightDate.ToString("yyyy-MM-dd")"
                               asp-route-flightClass="Бізнес"
                               asp-route-price="349"
                               class="booking-btn">
                                Забронювати
                            </a>
                        </div>
                    </div>

                    <div class="flight-footer">
                        <span>@Model.FlightDate.ToString("dd MMMM yyyy")</span>
                        <span>Бізнес</span>
                        <span>8 місць</span>
                    </div>
                </div>

                <!-- 3 -->
                <div class="flight-card" data-base-price="389">
                    <div class="flight-top">
                        <div class="airline-box">
                            <div class="airline-icon">✈</div>
                            <div>
                                <h3>Luftreise Airways</h3>
                                <p>LR 1240</p>
                            </div>
                        </div>
                    </div>

                    <div class="flight-main">
                        <div class="flight-time-block">
                            <h2>18:50</h2>
