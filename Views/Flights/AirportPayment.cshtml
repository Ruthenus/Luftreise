@model Luftreise_Luftreise.Presentation_.Models.BookingViewModel

@{
    ViewData["Title"] = "Бронювання підтверджено";
    var passengers = Model.Passengers ?? new List<Luftreise_Luftreise.Presentation_.Models.PassengerFormViewModel>();
    var firstPassenger = passengers.FirstOrDefault();
    var totalPrice = Model.Price;
    var bookingNumber = string.IsNullOrWhiteSpace(Model.BookingReference)
        ? "LR-" + DateTime.Now.ToString("HHmmss")
        : Model.BookingReference;
}

<div class="airport-payment-page">
    <div class="airport-payment-card">
        <div class="success-icon">✓</div>

        <h1>Бронювання підтверджено!</h1>

        <p class="subtitle" style="color:black;">
            Ваші квитки на рейс @Model.FlightNumber успішно заброньовано.
            Нижче показані місця та кількість квитків.
        </p>

        <div class="payment-info">
            <p><strong>Номер бронювання:</strong></p>
            <h2 class="booking-number">@bookingNumber</h2>
            <p><strong>Маршрут:</strong> @Model.FromCity → @Model.ToCity</p>
            <p><strong>Рейс:</strong> @Model.FlightNumber</p>
            <p><strong>Дата:</strong> @Model.FlightDate.ToString("dd.MM.yyyy")</p>
            <p><strong>Кількість квитків:</strong> @passengers.Count</p>
            
            <p><strong>Загальна ціна:</strong> @totalPrice €</p>
        </div>

        <div class="payment-info passenger-seats-info">
            <p><strong>Місця пасажирів:</strong></p>
            @for (var i = 0; i < passengers.Count; i++)
            {
                var passenger = passengers[i];
                <p>Пасажир @(i + 1): @passenger.FirstName @passenger.LastName, місце @passenger.SeatNumber</p>
            }
        </div>

        <div class="notice" style="color:black;">
            Будь ласка, прибудьте в аеропорт за 2 години до вильоту.

            
        </div>
        <div class="notice" style="color:dodgerblue;">
            ОПЛАТА В АЕРОПОРТІ 


        </div>

        <a asp-controller="Home" asp-action="Index" class="home-btn">
            На головну
        </a>
    </div>
</div>
