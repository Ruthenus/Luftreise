@model Luftreise_Luftreise.Presentation_.Models.User

<section class="profile-page">
    <div class="profile-wrapper">

        <div class="profile-details-card">
            <h2>Редагувати профіль</h2>

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="AvatarPath" />
                <input type="hidden" asp-for="IsAdmin" />

                <div class="profile-field">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" />
                    <span asp-validation-for="FullName" class="field-validation"></span>
                </div>

                <div class="profile-field">
                    <label>Email</label>
                    <input value="@Model.Email" disabled />
                </div>

                <div class="profile-field">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" />
                    <span asp-validation-for="Phone" class="field-validation"></span>
                </div>

                <div class="profile-field">
                    <label asp-for="City"></label>
                    <input asp-for="City" />
                    <span asp-validation-for="City" class="field-validation"></span>
                </div>

                <div class="profile-field">
                    <label asp-for="Country"></label>
                    <input asp-for="Country" />
                    <span asp-validation-for="Country" class="field-validation"></span>
                </div>

                <div class="profile-field">
                    <label asp-for="BirthDate"></label>
                    <input asp-for="BirthDate" type="date" />
                    <span asp-validation-for="BirthDate" class="field-validation"></span>
                </div>

                <div class="profile-field">
                    <label asp-for="AvatarFile">Фото профілю</label>
                    <input asp-for="AvatarFile" type="file" accept=".jpg,.jpeg,.png,.webp" />
                    <span asp-validation-for="AvatarFile" class="field-validation"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.AvatarPath))
                {
                    <div class="avatar-preview">
                        <img src="@Model.AvatarPath" alt="avatar preview" />
                    </div>
                }

                <button type="submit" class="auth-btn">Зберегти</button>
            </form>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}