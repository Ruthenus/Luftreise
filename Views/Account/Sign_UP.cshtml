@model Luftreise.Models.User

<div class="auth-page">
    <div class="auth-overlay"></div>

    <div class="auth-container">
        <div class="auth-card">
            <a asp-controller="Account" asp-action="Login" class="close-btn">✕</a>

            <div class="auth-left">
                <span class="auth-brand">Luftreise</span>
                <h1>Створіть акаунт</h1>
                <p>
                    Зареєструйтеся, щоб керувати бронюваннями, переглядати квитки
                    та користуватися можливостями сервісу.
                </p>

                <ul class="auth-benefits">
                    <li>Керування бронюваннями</li>
                    <li>Доступ до особистого кабінету</li>
                    <li>Швидке відновлення доступу</li>
                </ul>
            </div>

            <div class="auth-right">
                <div class="auth-header">
                    <h2>Реєстрація</h2>
                    <p>Заповніть дані для створення акаунта</p>
                </div>

                <form asp-action="Sign_UP" asp-controller="Account" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-group">
                        <label asp-for="FullName">ПІБ</label>
                        <input asp-for="FullName" />
                        <span asp-validation-for="FullName" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" />
                        <span asp-validation-for="Email" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">Телефон</label>
                        <input asp-for="Phone" />
                        <span asp-validation-for="Phone" class="field-validation" placeholder="+380..."></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="City">Місто</label>
                        <input asp-for="City" />
                        <span asp-validation-for="City" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Country">Країна</label>
                        <input asp-for="Country" />
                        <span asp-validation-for="Country" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="BirthDate">Дата народження</label>
                        <input asp-for="BirthDate" type="date" />
                        <span asp-validation-for="BirthDate" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password">Пароль</label>
                        <input asp-for="Password" type="password" />
                        <span asp-validation-for="Password" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword">Підтвердіть пароль</label>
                        <input asp-for="ConfirmPassword" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation"></span>
                    </div>

                    <button type="submit" class="auth-btn">Зареєструватися</button>

                    <div class="auth-footer">
                        <p>
                            Уже маєте акаунт?
                            <a asp-controller="Account" asp-action="Login">Увійти</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}